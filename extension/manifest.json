{
  "manifest_version": 3,
  "name": "Syntagma",
  "version": "0.1.0",
  "description": "AI-powered English vocabulary learning for Turkish speakers",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "contextMenus", "unlimitedStorage", "windows", "tabCapture"],
  "host_permissions": ["<all_urls>", "https://openrouter.ai/*", "https://api.dictionaryapi.dev/*", "http://localhost/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Syntagma"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "chunks/*", "dictionary.json", "reader.html", "video-player.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
