{
  "name": "syntagma-extension",
  "version": "0.1.0",
  "description": "Syntagma Chrome extension - AI-powered language learning",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npx tsc -b && npx vite build && npx vite build --config vite.content.config.ts",
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run",
    "test:youtube": "vitest run src/content/youtube-subtitles.test.ts -t \"live regression\"",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:netflix": "node test-netflix.mjs"
  },
  "dependencies": {
    "compromise": "^14.14.4",
    "lz-string": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "run": "^1.5.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.37",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
